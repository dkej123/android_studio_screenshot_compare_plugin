<idea-plugin>
    <id>com.github.dkwasniak.goldendiff.figma</id>
    <name>Golden Diff — Figma</name>
    <vendor email="damian.kwasniak@gmail.com">dkwasniak</vendor>

    <description><![CDATA[
      <p><b>Golden Diff — Figma</b> adds a Figma comparison source to the
      <b>Golden Diff</b> plugin: it lists the <code>figma-compose-preview</code> @Preview functions in
      the open file, downloads the referenced Figma frame, and compares it side-by-side with the
      current screenshot golden — reusing all of Golden Diff's compare modes.</p>

      <p>Requires the <b>Golden Diff</b> plugin. Distributed through an internal custom plugin
      repository, not the Marketplace.</p>
    ]]></description>

    <!-- Declares this as a modern IntelliJ Platform plugin, so it is compatible with all Platform
         IDEs (including Android Studio) rather than being treated as IntelliJ IDEA-only. Without a
         module dependency the IDE shows "Compatible with IntelliJ IDEA only" and refuses to load it
         elsewhere. -->
    <depends>com.intellij.modules.platform</depends>

    <!-- Depends on the public plugin: its classloader is the parent, so the public API (the
         comparisonSource extension point, GitImageSource, ScreenshotSettings, CurrentScreen) is
         visible here. Installing this plugin requires Golden Diff to be present. -->
    <depends>com.github.dkwasniak.goldendiff</depends>

    <extensions defaultExtensionNs="com.github.dkwasniak.goldendiff">
        <comparisonSource implementation="com.github.dkwasniak.goldendiff.compare.FigmaImageSource"/>
    </extensions>
</idea-plugin>
